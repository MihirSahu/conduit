{
  "name": "@conduit-llm/provider-chatgpt",
  "version": "0.1.1",
  "description": "ChatGPT subscription-backed Conduit provider with OAuth session storage and Codex backend transport.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/MihirSahu/conduit.git",
    "directory": "packages/provider-chatgpt"
  },
  "bugs": {
    "url": "https://github.com/MihirSahu/conduit/issues"
  },
  "homepage": "https://github.com/MihirSahu/conduit#readme",
  "keywords": ["conduit", "chatgpt", "codex", "llm", "oauth", "typescript"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@conduit-llm/core": "^0.1.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.2.0"
  }
}
