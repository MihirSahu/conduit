{
  "name": "@conduit-llm/cli",
  "version": "0.1.1",
  "description": "Bun-based Conduit CLI for ChatGPT subscription-backed Codex login, status, and prompts.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "conduit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/MihirSahu/conduit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/MihirSahu/conduit/issues"
  },
  "homepage": "https://github.com/MihirSahu/conduit#readme",
  "keywords": ["conduit", "chatgpt", "codex", "cli", "oauth"],
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@conduit-llm/core": "^0.1.1",
    "@conduit-llm/provider-chatgpt": "^0.1.1"
  }
}
