{
  "name": "@conduit-llm/core",
  "version": "0.1.1",
  "description": "Core provider interfaces, typed errors, events, redaction, and structured output helpers for Conduit.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/MihirSahu/conduit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/MihirSahu/conduit/issues"
  },
  "homepage": "https://github.com/MihirSahu/conduit#readme",
  "keywords": ["conduit", "llm", "ai", "structured-output", "typescript"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
